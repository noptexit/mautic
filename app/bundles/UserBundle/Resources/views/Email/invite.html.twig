<!DOCTYPE html>
<html>
    <body style="margin:0;padding:0;background:#f4f4f4;font-family:Arial,Helvetica,sans-serif;color:#1f2933;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f4f4;padding:24px 0;">
            <tr>
                <td align="center">
                    <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #dfe3e8;">
                        <tr>
                            <td style="padding:24px 32px;border-bottom:1px solid #dfe3e8;">
                                <strong style="font-size:20px;line-height:28px;">Mautic</strong>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:32px;">
                                <h1 style="margin:0 0 16px;font-size:24px;line-height:32px;font-weight:600;">{{ 'mautic.user.invite.email.heading'|trans }}</h1>
                                <p style="margin:0 0 24px;font-size:16px;line-height:24px;">{{ 'mautic.user.invite.email.intro'|trans }}</p>
                                <p style="margin:0 0 24px;">
                                    <a href="{{ inviteLink }}" style="display:inline-block;padding:12px 18px;background:#1b75bb;color:#ffffff;text-decoration:none;font-size:16px;line-height:20px;">{{ 'mautic.user.invite.register'|trans }}</a>
                                </p>
                                <p style="margin:0;font-size:14px;line-height:20px;color:#52616b;">{{ 'mautic.user.invite.email.fallback'|trans({'%invite_link%': inviteLink}) }}</p>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:20px 32px;border-top:1px solid #dfe3e8;font-size:12px;line-height:18px;color:#697b8c;">
                                {{ 'mautic.user.invite.email.footer'|trans }}
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
